# --- Desarrollo local (MySQL) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=db_agenda_metas
DB_PORT=3306
PORT=3000
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# --- Supabase (PostgreSQL) ---
# Local: conexión directa (puerto 5432)
# DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.TU_REF.supabase.co:5432/postgres

# Vercel: usa el POOLER (puerto 6543) — Supabase → Settings → Database → Connection string → Transaction pooler
# DATABASE_URL=postgresql://postgres.TU_REF:TU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# --- Variables para Vercel (backend) ---
# FRONTEND_URL=https://tu-frontend.vercel.app
# ALLOW_VERCEL_PREVIEWS=true
# NODE_ENV=production
