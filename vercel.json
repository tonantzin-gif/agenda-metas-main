{
  "buildCommand": "cd backend && npm install && cd ../frontend && npm install",
  "deployCommand": "echo 'Building individual services...'",
  "projects": {
    "frontend": {
      "root": "frontend",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "framework": "vite",
      "env": ["VITE_API_URL"]
    },
    "backend": {
      "root": "backend",
      "buildCommand": "npm install",
      "framework": "nodejs"
    }
  }
}
